<?xml version="1.0" encoding="UTF-8"?>
<beans
	xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="
			http://www.springframework.org/schema/beans
	   		http://www.springframework.org/schema/beans/spring-beans-3.0.xsd
	   		http://www.springframework.org/schema/context
	   		http://www.springframework.org/schema/context/spring-context-3.0.xsd">

	<!-- Configuració adicional per activar els mocks SCSP -->
	<!-- Aquest fitxer s'ha d'incloure quan es vulgui utilitzar els mocks -->

	<!-- Escaneja el paquet dels mocks per trobar ClienteUnicoMock i ClienteUnicoMockPersistent -->
	<context:component-scan base-package="es.caib.pinbal.scsp.mock" />

</beans>
